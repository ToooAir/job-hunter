# Copy this file to search_targets.yaml and customise for your own job search.
# All keyword lists support partial matching against job titles.

arbeitnow:
  keywords:
    - "Software Engineer"
    - "Backend Engineer"
    - "Backend Developer"
    - "Full Stack Engineer"
    - "AI Engineer"
    - "Python"
    - "Node.js"
    - "DevOps Engineer"
    - "Platform Engineer"
    # Integration / Solutions line
    - "Integration Engineer"
    - "Integration Developer"
    - "Solutions Engineer"
    - "Implementation Engineer"
    - "Technical Consultant"
    # Java / Kotlin ecosystem
    - "Java Developer"
    - "Kotlin Developer"
    # AI / Data extensions
    - "Applied AI Engineer"
    - "MLOps Engineer"
    # German equivalents (some DE companies use German titles even on English platforms)
    - "Softwareentwickler"
    - "Backend-Entwickler"
    - "Integrationsentwickler"
    - "Java Entwickler"
    - "IT-Berater"
  locations: ["Hamburg", "Berlin", "Remote", "Germany"]
  remote_filter: true
  max_pages: 5

englishjobs:
  base_urls:
    - "https://englishjobs.de/in/hamburg"
    - "https://englishjobs.de/in/berlin"
    - "https://englishjobs.de/in/munich"
    # Add more cities as needed: /in/frankfurt, /in/cologne, etc.
  keywords: ["Software", "Backend", "Integration", "Java", "Kotlin", "AI", "MLOps", "Solutions", "Engineer", "Python", "Node"]
  max_pages: 3

germantechjobs:
  keywords:
    # English titles
    - "Software Engineer"
    - "Backend Engineer"
    - "AI Engineer"
    - "Data Engineer"
    - "Integration Engineer"
    - "Java Developer"
    - "Kotlin Developer"
    - "Solutions Engineer"
    - "MLOps Engineer"
    # Tech keywords (matched against technologies field)
    - "Python"
    - "Node"
    - "TypeScript"
    - "Java"
    - "Kotlin"
    # German titles
    - "Softwareentwickler"
    - "Integrationsentwickler"
    - "Java Entwickler"
  target_cities:
    - "Hamburg"
    - "Berlin"
    - "Munich"
    # Add more German cities as needed
  include_remote: true
  max_detail_fetches: 60

bundesagentur:
  keywords:
    - "Software Engineer"
    - "Backend Engineer"
    - "Python Developer"
    - "DevOps Engineer"
    - "Integration Engineer"
    - "Java Developer"
    - "Kotlin Developer"
    - "Solutions Engineer"
    # German titles (Bundesagentur listings are often in German)
    - "Softwareentwickler"
    - "Backend-Entwickler"
    - "Integrationsentwickler"
    - "Java Entwickler"
    - "IT-Berater"
  location: "Hamburg"   # primary city
  radius_km: 50
  include_remote: true
  size: 100

remotive:
  categories:
    - "software-dev"
    - "devops-sysadmin"
    - "data"
  keywords:
    - "python"
    - "backend"
    - "node"
    - "engineer"
    - "fastapi"
    - "typescript"
    - "integration"
    - "java"
    - "kotlin"
    - "mlops"
  limit: 100

relocateme:
  base_url: "https://relocate.me/international-jobs/{category}"
  categories:
    - "backend"
    - "devops"
    - "python"
    - "javascript"
    - "full-stack"

jobicy:
  tags:
    - "python"
    - "backend"
    - "typescript"
    - "devops"
    - "cloud"
    - "java"
    - "kotlin"
  count: 50
  exclude_geo: ["USA Only", "US Only", "United States Only", "North America Only"]

greenhouse:
  # Public Job Board API — no auth required.
  # Verify a slug at: https://job-boards.greenhouse.io/{slug}
  # 404 slugs are silently skipped at runtime — safe to leave stale entries.
  keywords:
    - "software engineer"
    - "backend"
    - "python"
    - "node"
    - "devops"
    - "fullstack"
    - "ai engineer"
    - "platform engineer"
    - "integration engineer"
    - "java"
    - "kotlin"
    - "solutions engineer"
    - "data engineer"
  companies:
    # Add company slugs for firms you want to track directly.
    # Examples of well-known companies using Greenhouse:
    - contentful
    - adjust
    - mambu
    - hellofresh
    - sumup
    # Add more: https://job-boards.greenhouse.io/{slug}

lever:
  # Public Postings API — no auth required.
  # Verify a slug at: https://jobs.lever.co/{slug}
  # 404 slugs are silently skipped at runtime.
  keywords:
    - "software engineer"
    - "backend"
    - "python"
    - "node"
    - "devops"
    - "fullstack"
    - "ai engineer"
    - "integration engineer"
    - "java"
    - "kotlin"
    - "solutions engineer"
  companies:
    # Add company slugs for firms you want to track directly.
    # Examples of well-known companies using Lever:
    - trade-republic
    - billie
    - raisin
    - forto
    # Add more: https://jobs.lever.co/{slug}

linkedin_search_urls:
  # These open in your browser via the Dashboard's LinkedIn search buttons.
  # Customise keywords and location as needed.
  - "https://www.linkedin.com/jobs/search/?keywords=Software+Engineer&location=Hamburg%2C+Germany&f_WT=2%2C3"
  - "https://www.linkedin.com/jobs/search/?keywords=Backend+Engineer&location=Hamburg%2C+Germany&f_WT=2%2C3"
  - "https://www.linkedin.com/jobs/search/?keywords=AI+Engineer&location=Hamburg%2C+Germany&f_WT=2%2C3"
  - "https://www.linkedin.com/jobs/search/?keywords=Integration+Engineer&location=Hamburg%2C+Germany&f_WT=2%2C3"
  - "https://www.linkedin.com/jobs/search/?keywords=Java+Developer&location=Hamburg%2C+Germany&f_WT=2%2C3"
  - "https://www.linkedin.com/jobs/search/?keywords=Solutions+Engineer&location=Hamburg%2C+Germany&f_WT=2%2C3"
